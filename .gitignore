## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/
nul


# Visual Studio cache files
.vs/

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Distribution output
dist/
publish/
*.zip

# Claude
.claude
mcp-config.json
