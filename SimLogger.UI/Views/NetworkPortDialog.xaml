<Window x:Class="SimLogger.UI.Views.NetworkPortDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Configure Network Trigger"
        Height="340" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Configure UDP Network Trigger"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,16"/>

        <!-- Host/IP Input -->
        <TextBox x:Name="HostTextBox"
                 Grid.Row="1"
                 materialDesign:HintAssist.Hint="Target Host/IP"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- Port Input -->
        <TextBox x:Name="PortTextBox"
                 Grid.Row="2"
                 materialDesign:HintAssist.Hint="UDP Port (1-65535)"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 PreviewTextInput="PortTextBox_PreviewTextInput"
                 Margin="0,0,0,16"/>

        <!-- Description -->
        <TextBlock Grid.Row="3"
                   Text="A UDP packet will be sent to this address when a new shot is detected."
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   TextWrapping="Wrap"
                   Opacity="0.7"
                   VerticalAlignment="Top"/>

        <!-- Action Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Test button -->
            <Button x:Name="TestButton"
                    Grid.Column="0"
                    Content="Test Packet"
                    Click="TestButton_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>

            <!-- Right: Cancel and OK buttons -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal">
                <Button Content="Cancel"
                        Click="CancelButton_Click"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,8,0"/>
                <Button x:Name="OkButton"
                        Content="OK"
                        Click="OkButton_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
