<UserControl x:Class="SimLogger.UI.Views.ShotListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Shot History"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16"/>

        <!-- Filters -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding ClubFilters}"
                      SelectedItem="{Binding SelectedClubFilter}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="Filter by Club"/>
        </Grid>

        <!-- Shot Grid -->
        <DataGrid x:Name="ShotDataGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Shots}"
                  SelectedItem="{Binding SelectedShot}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="True"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  ColumnWidth="SizeToCells">

            <!-- Remove cell focus border -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <!-- Selection checkbox -->
                <DataGridTemplateColumn Header="Sel" Width="Auto" CanUserReorder="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Click="SelectionCheckBox_Click"
                                      Tag="{Binding}"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Basic Info -->
                <DataGridTextColumn Header="#"
                                    Binding="{Binding ShotNumber}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Time"
                                    Binding="{Binding DirectoryTimestamp, StringFormat=HH:mm:ss}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Date"
                                    Binding="{Binding DirectoryTimestamp, StringFormat=MMM d}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Club"
                                    Binding="{Binding ClubData.ClubName}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="To Pin"
                                    Binding="{Binding DistanceToTarget, StringFormat={}{0:F1} yds}"
                                    Width="Auto"/>

                <!-- Ball Data -->
                <DataGridTextColumn Header="Ball Speed"
                                    Binding="{Binding BallData.Speed}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Launch Angle"
                                    Binding="{Binding BallData.LaunchAngle}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Launch Dir"
                                    Binding="{Binding BallData.LaunchDirection}"
                                    Width="Auto"/>

                <!-- Club Data -->
                <DataGridTextColumn Header="Club Speed"
                                    Binding="{Binding ClubData.Speed}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Face Angle"
                                    Binding="{Binding ClubData.FaceAngle}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Swing Path"
                                    Binding="{Binding ClubData.SwingPath}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Attack Angle"
                                    Binding="{Binding ClubData.AttackAngle}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Face To Path"
                                    Binding="{Binding ClubData.FaceToPath}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Smash"
                                    Binding="{Binding SmashFactor}"
                                    Width="Auto"/>

                <!-- Spin Data -->
                <DataGridTextColumn Header="Total Spin"
                                    Binding="{Binding BallData.TotalSpin}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Back Spin"
                                    Binding="{Binding BallData.BackSpin}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Side Spin"
                                    Binding="{Binding BallData.SideSpin}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Spin Axis"
                                    Binding="{Binding BallData.SpinAxis}"
                                    Width="Auto"/>

                <!-- Flight Data -->
                <DataGridTextColumn Header="Carry"
                                    Binding="{Binding FlightData.Carry}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Total"
                                    Binding="{Binding FlightData.TotalDistance}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Offline"
                                    Binding="{Binding FlightData.OffLine}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Apex"
                                    Binding="{Binding FlightData.Apex}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Descent"
                                    Binding="{Binding FlightData.DescentAngle}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Air Time"
                                    Binding="{Binding FlightData.AirTime}"
                                    Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Pagination Controls -->
        <Border Grid.Row="3"
                Margin="0,8,0,0"
                Padding="12,6"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Showing X-Y of Z -->
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Opacity="0.7">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Showing {0}-{1} of {2} shots">
                            <Binding Path="DisplayStartIndex"/>
                            <Binding Path="DisplayEndIndex"/>
                            <Binding Path="TotalFilteredCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <!-- Center: Pagination buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Command="{Binding FirstPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="First page"
                            Width="32" Height="32">
                        <materialDesign:PackIcon Kind="PageFirst" Width="20" Height="20"/>
                    </Button>
                    <Button Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Previous page"
                            Width="32" Height="32">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                    </Button>

                    <TextBlock VerticalAlignment="Center"
                               Margin="12,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Page {0} of {1}">
                                <Binding Path="CurrentPage"/>
                                <Binding Path="TotalPages"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <Button Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Next page"
                            Width="32" Height="32">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                    </Button>
                    <Button Command="{Binding LastPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Last page"
                            Width="32" Height="32">
                        <materialDesign:PackIcon Kind="PageLast" Width="20" Height="20"/>
                    </Button>
                </StackPanel>

                <!-- Right: Page size (optional, empty for now) -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Bottom Actions -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Primary action buttons -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Selection info (only visible when items selected) -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Visibility="{Binding SelectedShots.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <TextBlock Text="{Binding SelectedShots.Count, StringFormat='{}{0} selected'}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               FontWeight="Medium"/>
                    <Button Content="Clear"
                            Command="{Binding ClearSelectionCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Padding="12,4"/>
                </StackPanel>

                <!-- Center: Primary action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="SyncButton"
                            Content="Sync All"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="SyncButton_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="ExportCsvButton"
                            Content="Export All"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="ExportCsvButton_Click"/>
                </StackPanel>

                <!-- Right: Sync progress panel (shown during sync) -->
                <StackPanel x:Name="SyncProgressPanel"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="Collapsed">
                    <ProgressBar x:Name="SyncProgressBar"
                                 Minimum="0" Maximum="100" Value="0"
                                 Width="120"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 VerticalAlignment="Center"/>
                    <TextBlock x:Name="SyncStatusText"
                               Text="Syncing..."
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.7"
                               Margin="8,0,8,0"
                               VerticalAlignment="Center"
                               MaxWidth="150"
                               TextTrimming="CharacterEllipsis"/>
                    <Button x:Name="CancelSyncButton"
                            Content="Cancel"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Click="CancelSyncButton_Click"
                            Padding="8,4"/>
                </StackPanel>
            </Grid>

            <!-- Row 1: Settings toggles -->
            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12,8"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Settings label -->
                    <TextBlock Grid.Column="0"
                               Text="SETTINGS"
                               Style="{StaticResource MaterialDesignOverlineTextBlock}"
                               VerticalAlignment="Center"
                               Opacity="0.5"
                               Margin="0,0,24,0"/>

                    <!-- Center: Toggle switches -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ToggleButton x:Name="AudioTriggerToggle"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="False"
                                      Checked="AudioTriggerToggle_Changed"
                                      Unchecked="AudioTriggerToggle_Changed"
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="Audio Trigger"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Opacity="0.7"
                                   Margin="8,0,4,0"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="AudioDeviceButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Click="AudioDeviceButton_Click"
                                ToolTip="Select audio output device"
                                Width="32" Height="32"
                                Padding="4">
                            <materialDesign:PackIcon Kind="Speaker" Width="18" Height="18"/>
                        </Button>

                        <Rectangle Width="1" Fill="{DynamicResource MaterialDesignDivider}" Margin="16,4"/>

                        <ToggleButton x:Name="NetworkTriggerToggle"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="False"
                                      Checked="NetworkTriggerToggle_Changed"
                                      Unchecked="NetworkTriggerToggle_Changed"
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="Network Trigger"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Opacity="0.7"
                                   Margin="8,0,4,0"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="NetworkPortButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Click="NetworkPortButton_Click"
                                ToolTip="Configure UDP port"
                                Width="32" Height="32"
                                Padding="4">
                            <materialDesign:PackIcon Kind="Lan" Width="18" Height="18"/>
                        </Button>

                        <Rectangle Width="1" Fill="{DynamicResource MaterialDesignDivider}" Margin="16,4"/>

                        <TextBlock Text="GSPro"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Opacity="0.7"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="GSProPathButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Click="GSProPathButton_Click"
                                ToolTip="Select GSPro installation folder"
                                Width="32" Height="32"
                                Padding="4">
                            <materialDesign:PackIcon Kind="Golf" Width="18" Height="18"/>
                        </Button>

                        <Rectangle Width="1" Fill="{DynamicResource MaterialDesignDivider}" Margin="16,4"/>

                        <TextBlock Text="Data Storage"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Opacity="0.7"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="DataStorageButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Click="DataStorageButton_Click"
                                ToolTip="Select data storage location"
                                Width="32" Height="32"
                                Padding="4">
                            <materialDesign:PackIcon Kind="FolderCog" Width="18" Height="18"/>
                        </Button>

                        <Rectangle Width="1" Fill="{DynamicResource MaterialDesignDivider}" Margin="16,4"/>

                        <TextBlock Text="Columns"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Opacity="0.7"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="ColumnsButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Click="ColumnsButton_Click"
                                ToolTip="Show/hide columns"
                                Width="32" Height="32"
                                Padding="4">
                            <materialDesign:PackIcon Kind="TableColumn" Width="18" Height="18"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Row 2: Status bar -->
            <Grid Grid.Row="2" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="MonitoringIndicator"
                             Width="8" Height="8"
                             Fill="#4CAF50"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="Monitoring"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.5"
                               Margin="6,0,12,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="|"
                               Opacity="0.3"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.7"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
